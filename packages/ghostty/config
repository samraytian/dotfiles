# Reload config with shift + cmd + ,

# Terminal
term = xterm-256color

# Theme
theme = Gruvbox Dark Hard

# Font
# Nerd Fonts are not necessary in Ghostty
# Alternatives: SF Mono, Hack, Maple Mono CN, Source Code Pro, JetBrains Maple Mono
font-family = JetBrains Maple Mono
font-size = 13
font-thicken = true

# Background
background-opacity-cells = true
background-opacity = 1.0
background-blur = true
background-blur-radius = 40

# Window
window-decoration = auto
window-padding-color = extend
window-padding-balance = true
window-padding-x = 8
window-padding-y = 0
window-height = 50
window-width = 145

# macOS
# Available values are: "native", "transparent", "tabs", and "hidden".
macos-titlebar-style = tabs
macos-option-as-alt = true

# Shell
shell-integration = zsh
shell-integration-features = no-cursor

# Mouse
mouse-hide-while-typing = true

# Cursor
cursor-style = block
cursor-style-blink = true
