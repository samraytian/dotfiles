#!/bin/bash

set -euo pipefail

# Match dotfiles (e.g. .gitconfig) when expanding "$src"/*
shopt -s nullglob dotglob

PKG_DIR="$HOME/dotfiles/packages"

# Package definitions: NAME|TYPE|MODE|DEST
#   NAME  entry name under PKG_DIR
#   TYPE  D = directory, F = file
#   MODE  - = link the entry itself, * = link every file inside the directory
#   DEST  HOME or CONFIG (target base directory)
PKGS=(
  "git|D|*|HOME"
  "zsh|D|*|HOME"
  "ghostty|D|-|CONFIG"
  "tmux|D|-|CONFIG"
  "starship.toml|F|-|CONFIG"
)

# Resolve a DEST keyword to an absolute base directory.
dest_dir() {
  case "$1" in
    HOME) printf '%s' "$HOME" ;;
    CONFIG) printf '%s' "$HOME/.config" ;;
    *) echo "dots: unknown destination '$1'" >&2; return 1 ;;
  esac
}

# Symlink $src -> $dst, replacing any existing real file/dir at $dst.
# Existing symlinks are left for `ln -sfn` to overwrite; only real
# files/dirs (which `ln` would otherwise link *into*) are removed.
link_one() {
  local src="$1" dst="$2"
  if [ -e "$dst" ] && [ ! -L "$dst" ]; then
    rm -rf "$dst"
  fi
  ln -sfn "$src" "$dst"
}

install() {
  local name mode dest target src f
  for entry in "${PKGS[@]}"; do
    IFS='|' read -r name _ mode dest <<< "$entry"
    target="$(dest_dir "$dest")"
    src="$PKG_DIR/$name"
    mkdir -p "$target"

    if [ "$mode" = "*" ]; then
      # Link every file inside the directory into the target
      for f in "$src"/*; do
        link_one "$f" "$target/$(basename "$f")"
      done
    else
      # Link the entry (file or directory) itself
      link_one "$src" "$target/$name"
    fi
  done
  echo "✅ Dotfiles symlinks created"
  return 0
}

uninstall() {
  local name mode dest target src f link
  for entry in "${PKGS[@]}"; do
    IFS='|' read -r name _ mode dest <<< "$entry"
    target="$(dest_dir "$dest")"
    src="$PKG_DIR/$name"

    if [ "$mode" = "*" ]; then
      for f in "$src"/*; do
        link="$target/$(basename "$f")"
        [ -L "$link" ] && rm -f "$link"
      done
    else
      link="$target/$name"
      [ -L "$link" ] && rm -f "$link"
    fi
  done
  echo "✅ Dotfiles symlinks removed"
  return 0
}

case "${1:-}" in
  install)
    install
    ;;
  uninstall)
    uninstall
    ;;
  *)
    echo "Usage: dots {install|uninstall}" >&2
    exit 1
    ;;
esac
